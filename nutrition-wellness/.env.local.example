# MongoDB
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?appName=Cluster0
MONGODB_DB=wellbeing_app

# Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Optional user for local testing
NEXT_PUBLIC_DEFAULT_USER_ID=demo-user

# Optional cron secret for /api/nutrition/insight-memory/finalize
NUTRITION_MEMORY_CRON_SECRET=replace_with_secret
